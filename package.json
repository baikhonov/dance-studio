{
  "name": "dance-studio",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "npm run dev:client",
    "dev:client": "vite",
    "dev:server": "npm run dev --prefix server",
    "dev:full": "concurrently -n client,server -c blue,green \"npm run dev:client\" \"npm run dev:server\"",
    "build": "vite build",
    "type-check": "vue-tsc --build",
    "preview": "vite preview",
    "lint": "run-s lint:*",
    "lint:oxlint": "oxlint . --fix",
    "lint:eslint": "eslint . --fix --cache",
    "format": "prettier --write --experimental-cli src/"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.2.1",
    "pinia": "^3.0.4",
    "vue": "^3.5.29",
    "vue-router": "^5.0.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.6.0",
    "@vitejs/plugin-vue": "^6.0.4",
    "@vue/tsconfig": "^0.9.1",
    "autoprefixer": "^10.4.27",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-oxlint": "~1.50.0",
    "eslint-plugin-vue": "~10.8.0",
    "globals": "^17.3.0",
    "concurrently": "^9.1.2",
    "npm-run-all2": "^8.0.4",
    "oxlint": "~1.50.0",
    "postcss": "^8.5.6",
    "prettier": "3.8.1",
    "sass-embedded": "^1.97.3",
    "tailwindcss": "^4.2.1",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.1",
    "vite": "^7.3.1",
    "vite-plugin-vue-devtools": "^8.0.6",
    "vue-tsc": "^3.2.6"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  }
}
