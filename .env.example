# Main local env file (copy to .env in project root).
# Used by docker compose and frontend Vite (VITE_* variables).

# Frontend
VITE_API_BASE_URL=http://localhost:3000

# Backend / Postgres (docker compose local stack)
POSTGRES_DB=dance_studio
POSTGRES_USER=dance
POSTGRES_PASSWORD=change-me
JWT_SECRET=change-me
ADMIN_PASSWORD=change-me
JWT_EXPIRES_IN=7d
CORS_ORIGIN=http://localhost:5173,http://localhost:8080