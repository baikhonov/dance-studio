# Optional backend-only env.
# Use this only when running backend directly from /server
# (for example: cd server && npm run dev).
# If you run via docker compose, prefer root .env instead.

PORT=3000
CORS_ORIGIN=http://localhost:5173
JWT_SECRET=change-me-in-production
ADMIN_PASSWORD=change-me
DATABASE_URL=postgres://dance:dance_password@localhost:5432/dance_studio
JWT_EXPIRES_IN=7d
# Comma-separated origins, or omit for permissive dev CORS
# CORS_ORIGIN=http://localhost:5173
